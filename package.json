{
  "name": "xjslt",
  "version": "1.0.0",
  "description": "xslt 2 transpiler to javascript",
  "keywords": [
    "xslt",
    "xslt2",
    "xslt3",
    "xml",
    "xpath",
    "transform"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "prebuild-preprocessors": "npm run build && rm src/preprocess/*js",
    "build-preprocessors": "bash -c \"for n in src/preprocess/*xsl ; do npm exec -- xjslt compile --standalone \\$n \\${n/xsl/js} ; done\"",
    "postbuild-preprocessors": "prettier -w src/preprocess/ && npm run build",
    "pretest": "if [ -d xslt30-test ] ; then cd xslt30-test && git pull && cd .. ; else git clone --depth 1 https://github.com/w3c/xslt30-test/ ; fi",
    "test": "jest --coverage --verbose",
    "check": "jest && prettier -c src/ test/",
    "prepare": "tsc && chmod +x dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "COPYING",
    "COPYING.LESSER"
  ],
  "main": "./dist/xjslt.js",
  "exports": "./dist/xjslt.js",
  "types": "./dist/xjslt.d.ts",
  "bin": {
    "xjslt": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:egh/xjslt.git"
  },
  "author": "Erik Hetzner",
  "license": "MIT",
  "homepage": "https://github.com/egh/xjslt",
  "devDependencies": {
    "@types/jest": "*",
    "jest": "*",
    "jest-simple-dot-reporter": "*",
    "prettier": "*",
    "ts-jest": "*",
    "ts-node": "*",
    "typescript": "*"
  },
  "dependencies": {
    "@types/estree": "^1.0.8",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "astring": "^1.9.0",
    "commander": "^14.0.3",
    "fontoxpath": "^3.34.0",
    "slimdom": "^4.3.5",
    "webpack": "^5.107.0"
  }
}
